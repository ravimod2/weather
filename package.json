{
  "name": "weather",
  "version": "1.0.0",
  "description": "A CLI tool for fetching weather data",
  "type": "module",
  "main": "src/index.js",
  "bin": {
    "weather": "./src/index.js"
  },
  "scripts": {
    "start": "node src/index.js",
    "lint": "eslint src",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "weather",
    "cli",
    "openweather"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.2",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^29.7.0",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "coverage",
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  }
}
